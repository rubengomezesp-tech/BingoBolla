"use client";

import { useEffect, useState } from "react";
import { useRouter } from "next/navigation";
import { sounds } from "@/lib/sound";
import { createClient } from "@/lib/supabase/client";

export default function DailyBonusButton({ onClaimed }: { onClaimed?: () => void }) {
  const supabase = createClient();
  const router = useRouter();
  const [status, setStatus] = useState<"loading" | "available" | "claimed">("loading");
  const [secondsLeft, setSecondsLeft] = useState(0);
  const [claiming, setClaiming] = useState(false);
  const [flash, setFlash] = useState<string | null>(null);

  useEffect(() => {
    (async () => {
      const { data } = await supabase.rpc("daily_bonus_status");
      if (data?.available) setStatus("available");
      else { setStatus("claimed"); setSecondsLeft(data?.seconds_left ?? 0); }
    })();
  }, []);

  useEffect(() => {
    if (status !== "claimed" || secondsLeft <= 0) return;
    const id = setInterval(() => {
      setSecondsLeft((s) => {
        if (s <= 1) { setStatus("available"); return 0; }
        return s - 1;
      });
    }, 1000);
    return () => clearInterval(id);
  }, [status, secondsLeft]);

  async function claim() {
    setClaiming(true);
    const { data, error } = await supabase.rpc("claim_daily_bonus");
    setClaiming(false);
    if (error || data?.error) {
      if (data?.seconds_left) { setStatus("claimed"); setSecondsLeft(data.seconds_left); }
      return;
    }
    setFlash(`+500 🪙 +$0.50 💎`); sounds.bonus(); setTimeout(function(){router.refresh();}, 1200); sounds.bonus(); setTimeout(function(){router.refresh();}, 1200); sounds.bonus(); setTimeout(function(){router.refresh();}, 1200);
    setStatus("claimed");
    setSecondsLeft(24 * 3600);
    setTimeout(() => setFlash(null), 4000);
    onClaimed?.();
  }

  function fmt(s: number) {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    return `${h}h ${m}m`;
  }

  if (status === "loading") {
    return <div className="rounded-2xl px-5 py-3 bg-white/5 animate-pulse h-12 w-64" />;
  }

  if (status === "claimed") {
    return (
      <div className="rounded-2xl px-5 py-3 bg-white/[0.04] border border-white/10 text-sm font-mono text-white/50 flex items-center gap-2">
        🎁 Vuelve en {fmt(secondsLeft)}
      </div>
    );
  }

  return (
    <button
      onClick={claim}
      disabled={claiming}
      className="relative rounded-2xl px-5 py-3 font-medium text-sm text-black overflow-hidden transition-all hover:brightness-110 disabled:opacity-60"
      style={{ background: "linear-gradient(135deg, #FFD93D, #C8941A)" }}
    >
      <span className="relative z-10">
        {flash ? flash : claiming ? "Reclamando..." : "🎁 Bonus diario · 500 🪙 + $0.50 💎"}
      </span>
      <span className="absolute inset-0 opacity-30"
        style={{ background: "radial-gradient(circle at 30% 50%, #fff, transparent 60%)" }} />
    </button>
  );
}
