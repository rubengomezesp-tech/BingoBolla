# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# supabase cli cache
supabase/.temp/

# local agent hooks
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Capacitor — plataformas nativas generadas en la Mac del usuario
# (descomenta si NO quieres versionar los proyectos nativos)
# /ios
# /android

# Capacitor — archivos sensibles que nunca deben subirse
/android/keystore.properties
/android/app/google-services.json
*.keystore
*.jks
/ios/App/App/GoogleService-Info.plist
.env
.env.*
*.env
credentials.json
*.key
.credentials
